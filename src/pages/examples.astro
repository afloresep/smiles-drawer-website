---
import Layout from '../layouts/Layout.astro';
import MoleculeCard from '../components/MoleculeCard.astro';
import {molecules, reactions, renderOverrides, weightExamples} from '../data/molecules.js';
import {themeOptions, themePresets, themeSurfaceModes} from '../data/themes.js';

const moleculeCategories = [
    {key: 'simple', title: 'Simple Molecules', description: 'Basic organic structures and the fastest path to sanity-checking a render preset.'},
    {key: 'aromatic', title: 'Aromatic Rings', description: 'Aromatics, fused rings, and common systems where spacing and bond clarity matter.'},
    {key: 'heterocycles', title: 'Heterocycles', description: 'Nitrogen-, oxygen-, and sulfur-containing rings that quickly expose label crowding.'},
    {key: 'drugs', title: 'Drugs', description: 'Common pharmaceutical structures with stereochemistry and denser functional group labeling.'},
    {key: 'complex', title: 'Complex Molecules', description: 'Larger structures where automatic sizing and selective overrides make the biggest difference.'},
    {key: 'stereo', title: 'Stereochemistry', description: 'Chiral examples for checking wedge bonds, hydrogens, and compact drawing tradeoffs.'},
];

const allNavItems = [
    ...moleculeCategories.map(c => ({key: c.key, title: c.title})),
    {key: 'reactions', title: 'Reactions'},
    {key: 'weights', title: 'Weights'},
];
---
<Layout title="Examples" description="Gallery of molecules, reactions, and atom-weight overlays rendered with SmilesDrawer.">
    <section class="border-b border-ink bg-paper">
        <div class="max-w-7xl mx-auto px-6 py-10">
            <div class="eyebrow mb-2">03 / EXAMPLES</div>
            <h1 class="text-[34px] sm:text-[40px] font-extrabold tracking-[-0.025em] text-ink">Reference renders.</h1>
            <p class="mt-3 max-w-2xl text-[14px] text-ink-muted">
                Molecules, reactions, and weighted overlays across every theme. Click a card to open in the playground.
            </p>
        </div>
    </section>

    <section class="border-b border-rule bg-white sticky top-[65px] z-30">
        <div class="max-w-7xl mx-auto px-6 py-3 flex flex-wrap items-center gap-3">
            <div class="flex flex-wrap gap-1">
                {allNavItems.map(item => (
                    <a
                        href={`#${item.key}`}
                        class="text-[10px] font-bold uppercase tracking-[0.06em] px-2.5 py-1.5 border border-rule rounded-sm text-ink hover:border-mint hover:bg-mint-tint transition-colors">
                        {item.title}
                    </a>
                ))}
            </div>
            <div class="ml-auto flex items-center gap-2">
                <label for="gallery-theme" class="text-[10px] font-bold uppercase tracking-[0.12em] text-ink-hint">THEME</label>
                <select id="gallery-theme" class="text-[11px] font-mono border border-rule rounded-sm px-2 py-1 bg-white">
                    {themeOptions.map(option => (
                        <option value={option.value}>{option.label}</option>
                    ))}
                </select>
            </div>
        </div>
    </section>

    <div class="max-w-7xl mx-auto px-6 py-12">

        {moleculeCategories.map(cat => (
            <section id={cat.key} class="mb-16 scroll-mt-24 border-t border-rule pt-8">
                <div class="max-w-3xl mb-6">
                    <h2 class="text-2xl font-bold tracking-[-0.03em] text-gray-900 dark:text-white">{cat.title}</h2>
                    <p class="mt-2 text-sm sm:text-base text-gray-500 dark:text-gray-400">{cat.description}</p>
                </div>
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
                    {molecules[cat.key].map(mol => (
                        <MoleculeCard
                            name={mol.name}
                            render={renderOverrides[mol.smiles]}
                            showDownload={true}
                            showPlaygroundLink={true}
                            smiles={mol.smiles}
                        />
                    ))}
                </div>
            </section>
        ))}

        <section id="reactions" class="mb-16 scroll-mt-24 border-t border-rule pt-8">
            <div class="max-w-3xl mb-6">
                <h2 class="text-2xl font-bold tracking-[-0.03em] text-gray-900 dark:text-white">Reactions</h2>
                <p class="mt-2 text-sm sm:text-base text-gray-500 dark:text-gray-400">Reaction SMILES rendered with reagent placement and arrow annotations intact.</p>
            </div>
            <div class="flex flex-col gap-4 max-w-4xl mx-auto">
                {reactions.map(rxn => (
                    <MoleculeCard
                        name={rxn.name}
                        render={renderOverrides[rxn.smiles]}
                        showDownload={true}
                        showPlaygroundLink={true}
                        smiles={rxn.smiles}
                        wide
                    />
                ))}
            </div>
        </section>

        <section id="weights" class="scroll-mt-24 border-t border-rule pt-8">
            <div class="max-w-3xl mb-6">
                <h2 class="text-2xl font-bold tracking-[-0.03em] text-gray-900 dark:text-white">Weights / Heatmap</h2>
                <p class="mt-2 text-sm sm:text-base text-gray-500 dark:text-gray-400">Per-atom signed values rendered into a red/green overlay, using the same site themes as the rest of the gallery.</p>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
                {weightExamples.map(ex => (
                    <MoleculeCard
                        name={ex.name}
                        render={renderOverrides[ex.smiles]}
                        showDownload={true}
                        smiles={ex.smiles}
                        weights={ex.weights}
                    />
                ))}
            </div>
        </section>
    </div>

</Layout>

<script is:inline define:vars={{themePresets, themeSurfaceModes}}>
document.addEventListener('DOMContentLoaded', function() {
    var manualTheme = null;
    var site = window.SmilesWebsite;
    var themeSelect = document.getElementById('gallery-theme');

    function getDrawTheme() {
        return document.documentElement.classList.contains('dark') ? 'dark' : 'light';
    }

    function parseWeights(value) {
        return value.split(',').map(function(part) {
            return parseFloat(part.trim());
        }).filter(function(weight) {
            return !isNaN(weight);
        });
    }

    function renderAll() {
        var theme = manualTheme || getDrawTheme();

        document.querySelectorAll('[data-theme-surface="true"]').forEach(function(surface) {
            site.applyThemeSurface(surface, theme, themePresets, themeSurfaceModes);
        });

        document.querySelectorAll('.molecule-svg').forEach(function(svg) {
            var smiles = svg.getAttribute('data-smiles');
            var weightsAttr = svg.getAttribute('data-smiles-weights');
            var highlightsAttr = svg.getAttribute('data-smiles-highlights');
            var reactionWeightsAttr = svg.getAttribute('data-smiles-reaction-weights');
            var surface = svg.closest('[data-theme-surface]');
            var weights = weightsAttr ? parseWeights(weightsAttr) : null;
            var highlights = null;
            if (highlightsAttr) {
                try { highlights = JSON.parse(highlightsAttr); } catch (e) { highlights = null; }
            }
            var reactionWeights = null;
            if (reactionWeightsAttr) {
                try { reactionWeights = JSON.parse(reactionWeightsAttr); } catch (e) { reactionWeights = null; }
            }
            var defaults = site.getDefaultRenderOptions();

            if (!smiles) return;

            svg = site.renderSmiles({
                adaptive: true,
                baseOptions: {
                    width: defaults.width,
                    height: defaults.height,
                    explicitHydrogens: false,
                    padding: defaults.padding,
                    bondLength: defaults.bondLength,
                    bondThickness: defaults.bondThickness,
                    shortBondLength: defaults.shortBondLength,
                    bondSpacing: defaults.bondSpacing,
                    fontSizeLarge: defaults.fontSizeLarge,
                    scale: defaults.scale,
                    themes: themePresets
                },
                layout: {
                    containerWidth: surface && surface.clientWidth ? surface.clientWidth : 0,
                    minHeight: site.isReaction(smiles) ? 160 : 0
                },
                onError: function() {},
                renderConfig: site.getRenderConfig(svg),
                smiles: smiles,
                svg: svg,
                themeName: theme,
                weights: weights && weights.length ? weights : null,
                highlights: highlights && highlights.length ? highlights : null,
                reactionWeights: reactionWeights
            }).svg;
        });
    }

    site.waitForFonts(renderAll);

    new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            if (mutation.attributeName === 'class') {
                if (themeSelect && !manualTheme) {
                    themeSelect.value = getDrawTheme();
                }
                renderAll();
            }
        });
    }).observe(document.documentElement, {attributes: true, attributeFilter: ['class']});

    if (themeSelect) {
        themeSelect.value = getDrawTheme();
        themeSelect.addEventListener('change', function() {
            manualTheme = this.value;
            renderAll();
        });
    }

    var resizeTimer;
    window.addEventListener('resize', function() {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(renderAll, 120);
    });

    document.querySelectorAll('.download-svg-btn').forEach(function(button) {
        button.addEventListener('click', function(event) {
            var targetId = this.getAttribute('data-target');
            var svg = document.getElementById(targetId);
            var svgData;
            var blob;
            var url;
            var link;

            event.stopPropagation();
            if (!svg) return;

            svgData = new XMLSerializer().serializeToString(svg);
            blob = new Blob([svgData], {type: 'image/svg+xml'});
            url = URL.createObjectURL(blob);
            link = document.createElement('a');
            link.href = url;
            link.download = targetId + '.svg';
            link.click();
            URL.revokeObjectURL(url);
        });
    });
});
</script>
