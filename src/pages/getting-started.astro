---
import Layout from '../layouts/Layout.astro';
import CodeBlock from '../components/CodeBlock.astro';
---
<Layout title="Getting Started" description="Learn how to add SmilesDrawer to your project. CDN, npm, React, Vue, Svelte — we've got you covered.">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-2">Getting Started</h1>
        <p class="text-lg text-gray-600 dark:text-gray-400 mb-12">Three ways to start drawing molecules.</p>

        <!-- Path 1: CDN -->
        <section class="mb-16">
            <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center w-8 h-8 rounded-full bg-accent/10 text-accent font-bold text-sm">1</span>
                <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Just add a script tag</h2>
            </div>
            <p class="text-gray-600 dark:text-gray-400 mb-4 ml-11">
                The fastest path. No build tools, no npm, no framework. Perfect for quick prototypes, Jupyter notebooks, or static HTML pages.
            </p>
            <div class="ml-11">
                <CodeBlock
                    lang="html"
                    filename="index.html"
                    code={`<!DOCTYPE html>
<html>
<head>
    <script src="https://unpkg.com/smiles-drawer@2.1.7/dist/smiles-drawer.min.js"><\/script>
</head>
<body>
    <svg data-smiles="c1ccccc1"></svg>
    <svg data-smiles="CC(=O)Oc1ccccc1C(=O)O"></svg>

    <script>SmiDrawer.apply();<\/script>
</body>
</html>`}
                />
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-3">
                    <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded">SmiDrawer.apply()</code> scans the page for any element with a <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded">data-smiles</code> attribute and renders the molecule into it. Works with both <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded">&lt;svg&gt;</code> and <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded">&lt;canvas&gt;</code> elements.
                </p>
            </div>
        </section>

        <!-- Path 2: npm -->
        <section class="mb-16">
            <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center w-8 h-8 rounded-full bg-accent/10 text-accent font-bold text-sm">2</span>
                <h2 class="text-xl font-semibold text-gray-900 dark:text-white">npm install</h2>
            </div>
            <p class="text-gray-600 dark:text-gray-400 mb-4 ml-11">
                For bundled applications. Import as an ES module.
            </p>
            <div class="ml-11 space-y-4">
                <CodeBlock
                    lang="bash"
                    code="npm install smiles-drawer"
                />
                <CodeBlock
                    lang="javascript"
                    filename="app.js"
                    code={`import SmilesDrawer from 'smiles-drawer';

// Option 1: Quick apply (scans DOM for data-smiles attributes)
SmilesDrawer.SmiDrawer.apply();

// Option 2: Programmatic drawing
const drawer = new SmilesDrawer.SvgDrawer({ width: 500, height: 500 });
const svgElement = document.getElementById('my-molecule');

SmilesDrawer.parse('c1ccccc1', function(tree) {
    drawer.draw(tree, svgElement, 'light');
}, function(err) {
    console.error('Parse error:', err);
});`}
                />
            </div>
        </section>

        <!-- Path 3: Frameworks -->
        <section class="mb-16">
            <div class="flex items-center gap-3 mb-4">
                <span class="flex items-center justify-center w-8 h-8 rounded-full bg-accent/10 text-accent font-bold text-sm">3</span>
                <h2 class="text-xl font-semibold text-gray-900 dark:text-white">Framework examples</h2>
            </div>

            <div class="ml-11 space-y-8">
                <!-- React -->
                <div>
                    <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-3">React</h3>
                    <CodeBlock
                        lang="jsx"
                        filename="MoleculeViewer.jsx"
                        code={`import { useRef, useEffect } from 'react';
import SmilesDrawer from 'smiles-drawer';

export default function MoleculeViewer({ smiles, theme = 'light' }) {
    const svgRef = useRef(null);

    useEffect(() => {
        if (!svgRef.current || !smiles) return;
        const drawer = new SmilesDrawer.SvgDrawer({ width: 400, height: 400 });
        SmilesDrawer.parse(smiles, (tree) => {
            svgRef.current.innerHTML = '';
            drawer.draw(tree, svgRef.current, theme);
        }, (err) => console.error(err));
    }, [smiles, theme]);

    return <svg ref={svgRef} />;
}`}
                    />
                </div>

                <!-- Vue -->
                <div>
                    <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-3">Vue</h3>
                    <CodeBlock
                        lang="vue"
                        filename="MoleculeViewer.vue"
                        code={`<template>
  <svg ref="svgEl"></svg>
</template>

<script setup>
import { ref, watch, onMounted } from 'vue';
import SmilesDrawer from 'smiles-drawer';

const props = defineProps({ smiles: String, theme: { type: String, default: 'light' } });
const svgEl = ref(null);

function draw() {
  if (!svgEl.value || !props.smiles) return;
  const drawer = new SmilesDrawer.SvgDrawer({ width: 400, height: 400 });
  SmilesDrawer.parse(props.smiles, (tree) => {
    svgEl.value.innerHTML = '';
    drawer.draw(tree, svgEl.value, props.theme);
  }, (err) => console.error(err));
}

onMounted(draw);
watch(() => [props.smiles, props.theme], draw);
<\/script>`}
                    />
                </div>

                <!-- Svelte -->
                <div>
                    <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-3">Svelte</h3>
                    <CodeBlock
                        lang="svelte"
                        filename="MoleculeViewer.svelte"
                        code={`<script>
  import SmilesDrawer from 'smiles-drawer';
  import { onMount, afterUpdate } from 'svelte';

  export let smiles = '';
  export let theme = 'light';

  let svgEl;

  function draw() {
    if (!svgEl || !smiles) return;
    const drawer = new SmilesDrawer.SvgDrawer({ width: 400, height: 400 });
    SmilesDrawer.parse(smiles, (tree) => {
      svgEl.innerHTML = '';
      drawer.draw(tree, svgEl, theme);
    }, (err) => console.error(err));
  }

  onMount(draw);
  afterUpdate(draw);
<\/script>

<svg bind:this={svgEl}></svg>`}
                    />
                </div>

                <!-- data-smiles pattern -->
                <div>
                    <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-3">HTML data-attribute pattern</h3>
                    <p class="text-gray-600 dark:text-gray-400 mb-3 text-sm">
                        The simplest approach for static content. Just set <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded">data-smiles</code> on any SVG or canvas element and call <code class="text-xs bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded">apply()</code>.
                    </p>
                    <CodeBlock
                        lang="html"
                        code={`<!-- Molecules render automatically -->
<svg data-smiles="CCO" data-smiles-theme="light"></svg>
<svg data-smiles="c1ccccc1" data-smiles-theme="dark"></svg>
<canvas data-smiles="CC(=O)O"></canvas>

<script>
  // Options can be passed to apply()
  SmiDrawer.apply({ bondThickness: 1.5, fontSizeLarge: 8 });
<\/script>`}
                    />
                </div>
            </div>
        </section>

        <!-- Options reference -->
        <section>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Options Reference</h2>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-700">
                            <th class="text-left py-3 pr-4 font-medium text-gray-900 dark:text-white">Option</th>
                            <th class="text-left py-3 pr-4 font-medium text-gray-900 dark:text-white">Type</th>
                            <th class="text-left py-3 pr-4 font-medium text-gray-900 dark:text-white">Default</th>
                            <th class="text-left py-3 font-medium text-gray-900 dark:text-white">Description</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-600 dark:text-gray-400">
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">width</td>
                            <td class="py-2 pr-4">Number</td>
                            <td class="py-2 pr-4 font-mono text-xs">500</td>
                            <td class="py-2">Width of the drawing canvas</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">height</td>
                            <td class="py-2 pr-4">Number</td>
                            <td class="py-2 pr-4 font-mono text-xs">500</td>
                            <td class="py-2">Height of the drawing canvas</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">bondLength</td>
                            <td class="py-2 pr-4">Number</td>
                            <td class="py-2 pr-4 font-mono text-xs">15</td>
                            <td class="py-2">Length of bonds in pixels</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">bondThickness</td>
                            <td class="py-2 pr-4">Number</td>
                            <td class="py-2 pr-4 font-mono text-xs">1.0</td>
                            <td class="py-2">Thickness of bonds</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">bondSpacing</td>
                            <td class="py-2 pr-4">Number</td>
                            <td class="py-2 pr-4 font-mono text-xs">0.18</td>
                            <td class="py-2">Spacing between double/triple bonds (fraction of bond length)</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">shortBondLength</td>
                            <td class="py-2 pr-4">Number</td>
                            <td class="py-2 pr-4 font-mono text-xs">0.85</td>
                            <td class="py-2">Length of short bonds (fraction of bond length)</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">isomeric</td>
                            <td class="py-2 pr-4">Boolean</td>
                            <td class="py-2 pr-4 font-mono text-xs">true</td>
                            <td class="py-2">Display stereochemistry (wedge/dash bonds)</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">debug</td>
                            <td class="py-2 pr-4">Boolean</td>
                            <td class="py-2 pr-4 font-mono text-xs">false</td>
                            <td class="py-2">Show vertex indices and ring info</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">terminalCarbons</td>
                            <td class="py-2 pr-4">Boolean</td>
                            <td class="py-2 pr-4 font-mono text-xs">false</td>
                            <td class="py-2">Show terminal carbon labels (CH3, etc.)</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">explicitHydrogens</td>
                            <td class="py-2 pr-4">Boolean</td>
                            <td class="py-2 pr-4 font-mono text-xs">false</td>
                            <td class="py-2">Show explicit hydrogen atoms</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">compactDrawing</td>
                            <td class="py-2 pr-4">Boolean</td>
                            <td class="py-2 pr-4 font-mono text-xs">true</td>
                            <td class="py-2">Use compact layout for macrocycles</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">padding</td>
                            <td class="py-2 pr-4">Number</td>
                            <td class="py-2 pr-4 font-mono text-xs">20.0</td>
                            <td class="py-2">Padding around the molecule drawing</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">fontSizeLarge</td>
                            <td class="py-2 pr-4">Number</td>
                            <td class="py-2 pr-4 font-mono text-xs">6</td>
                            <td class="py-2">Font size for atom labels</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">fontSizeSmall</td>
                            <td class="py-2 pr-4">Number</td>
                            <td class="py-2 pr-4 font-mono text-xs">4</td>
                            <td class="py-2">Font size for subscripts (e.g., H count)</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">overlapSensitivity</td>
                            <td class="py-2 pr-4">Number</td>
                            <td class="py-2 pr-4 font-mono text-xs">0.42</td>
                            <td class="py-2">Sensitivity for overlap detection</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">overlapResolutionIterations</td>
                            <td class="py-2 pr-4">Number</td>
                            <td class="py-2 pr-4 font-mono text-xs">1</td>
                            <td class="py-2">Number of overlap resolution iterations</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">experimental</td>
                            <td class="py-2 pr-4">Boolean</td>
                            <td class="py-2 pr-4 font-mono text-xs">false</td>
                            <td class="py-2">Enable experimental features</td>
                        </tr>
                        <tr class="border-b border-gray-100 dark:border-gray-800">
                            <td class="py-2 pr-4 font-mono text-xs">themes</td>
                            <td class="py-2 pr-4">Object</td>
                            <td class="py-2 pr-4 font-mono text-xs">{`{...}`}</td>
                            <td class="py-2">Custom color themes (light/dark)</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</Layout>
