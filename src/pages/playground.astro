---
import Layout from '../layouts/Layout.astro';
import {playgroundPresets} from '../data/molecules.js';
---
<Layout title="Playground" description="Interactive SMILES molecule drawing playground. Paste a SMILES string and get an instant molecular structure depiction.">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="mb-6">
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Playground</h1>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Enter a SMILES string to render a molecule instantly.</p>
        </div>

        <!-- Tab bar -->
        <div class="flex gap-1 mb-6 border-b border-gray-200 dark:border-gray-700">
            <button id="tab-single" class="px-4 py-2 text-sm font-medium border-b-2 border-accent text-accent transition-colors">Single</button>
            <button id="tab-batch" class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">Batch Export</button>
        </div>

        <!-- Single mode panel -->
        <div id="panel-single">
            <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-6">
                <!-- Main area -->
                <div class="space-y-4">
                    <!-- SMILES input -->
                    <div class="flex gap-3">
                        <input
                            id="pg-input"
                            type="text"
                            value="c1ccccc1"
                            placeholder="Enter a SMILES string..."
                            class="flex-1 px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white text-lg font-mono focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all"
                            spellcheck="false"
                            autocomplete="off"
                        />
                        <button id="pg-draw-btn" class="btn-primary">Draw</button>
                    </div>

                    <!-- Error display -->
                    <div id="pg-error" class="text-sm text-red-500 dark:text-red-400 hidden"></div>

                    <!-- Molecule rendering area -->
                    <div class="card p-4 sm:p-8">
                        <div class="flex items-center justify-center" style="min-height: 400px;">
                            <svg id="pg-svg" class="w-full" style="max-width: 500px; max-height: 500px;"></svg>
                        </div>
                    </div>

                    <!-- Action buttons -->
                    <div class="flex flex-wrap gap-3">
                        <button id="pg-download-svg" class="btn-secondary">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                            </svg>
                            Download SVG
                        </button>
                        <button id="pg-download-png" class="btn-secondary">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                            </svg>
                            Download PNG
                        </button>
                        <button id="pg-copy-svg" class="btn-secondary">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                            </svg>
                            Copy SVG
                        </button>
                        <button id="pg-copy-smiles" class="btn-secondary">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                            </svg>
                            Copy SMILES
                        </button>
                        <button id="pg-share" class="btn-secondary">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                            </svg>
                            Share Link
                        </button>
                    </div>

                    <!-- Molecular formula (if computed) -->
                    <div id="pg-formula" class="text-sm text-gray-500 dark:text-gray-400 hidden">
                        Formula: <span id="pg-formula-text" class="font-mono"></span>
                    </div>
                </div>

                <!-- Sidebar -->
                <div class="space-y-4">
                    <!-- Options Panel -->
                    <details class="card" open>
                        <summary class="px-4 py-3 cursor-pointer text-sm font-medium text-gray-900 dark:text-white select-none hover:bg-gray-50 dark:hover:bg-gray-800 rounded-t-xl">
                            Options
                        </summary>
                        <div class="px-4 pb-4 space-y-4 border-t border-gray-100 dark:border-gray-800 pt-4">
                            <div>
                                <label class="flex items-center justify-between text-xs text-gray-600 dark:text-gray-400 mb-1">
                                    <span>Bond length</span>
                                    <span id="opt-bondLength-val" class="font-mono">15</span>
                                </label>
                                <input id="opt-bondLength" type="range" min="5" max="30" value="15" step="1" class="w-full accent-accent">
                            </div>
                            <div>
                                <label class="flex items-center justify-between text-xs text-gray-600 dark:text-gray-400 mb-1">
                                    <span>Bond thickness</span>
                                    <span id="opt-bondThickness-val" class="font-mono">1</span>
                                </label>
                                <input id="opt-bondThickness" type="range" min="0.5" max="5" value="1" step="0.5" class="w-full accent-accent">
                            </div>
                            <div>
                                <label class="flex items-center justify-between text-xs text-gray-600 dark:text-gray-400 mb-1">
                                    <span>Bond spacing</span>
                                    <span id="opt-bondSpacing-val" class="font-mono">0.18</span>
                                </label>
                                <input id="opt-bondSpacing" type="range" min="0.05" max="0.5" value="0.18" step="0.01" class="w-full accent-accent">
                            </div>
                            <div>
                                <label class="flex items-center justify-between text-xs text-gray-600 dark:text-gray-400 mb-1">
                                    <span>Font size</span>
                                    <span id="opt-fontSizeLarge-val" class="font-mono">6</span>
                                </label>
                                <input id="opt-fontSizeLarge" type="range" min="2" max="16" value="6" step="1" class="w-full accent-accent">
                            </div>
                            <div>
                                <label class="flex items-center justify-between text-xs text-gray-600 dark:text-gray-400 mb-1">
                                    <span>Canvas width</span>
                                    <span id="opt-width-val" class="font-mono">500</span>
                                </label>
                                <input id="opt-width" type="range" min="200" max="1000" value="500" step="50" class="w-full accent-accent">
                            </div>
                            <div>
                                <label class="flex items-center justify-between text-xs text-gray-600 dark:text-gray-400 mb-1">
                                    <span>Canvas height</span>
                                    <span id="opt-height-val" class="font-mono">500</span>
                                </label>
                                <input id="opt-height" type="range" min="200" max="1000" value="500" step="50" class="w-full accent-accent">
                            </div>
                            <hr class="border-gray-100 dark:border-gray-800" />
                            <label class="flex items-center justify-between text-xs">
                                <span class="text-gray-600 dark:text-gray-400">Terminal carbons</span>
                                <input id="opt-terminalCarbons" type="checkbox" class="accent-accent w-4 h-4">
                            </label>
                            <label class="flex items-center justify-between text-xs">
                                <span class="text-gray-600 dark:text-gray-400">Explicit hydrogens</span>
                                <input id="opt-explicitHydrogens" type="checkbox" class="accent-accent w-4 h-4">
                            </label>
                            <label class="flex items-center justify-between text-xs">
                                <span class="text-gray-600 dark:text-gray-400">Compact drawing</span>
                                <input id="opt-compactDrawing" type="checkbox" class="accent-accent w-4 h-4">
                            </label>
                            <label class="flex items-center justify-between text-xs">
                                <span class="text-gray-600 dark:text-gray-400">Debug mode</span>
                                <input id="opt-debug" type="checkbox" class="accent-accent w-4 h-4">
                            </label>
                            <hr class="border-gray-100 dark:border-gray-800" />
                            <label class="flex items-center justify-between text-xs">
                                <span class="text-gray-600 dark:text-gray-400">Theme</span>
                                <select id="opt-theme" class="text-xs bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded px-2 py-1">
                                    <option value="light">Light</option>
                                    <option value="dark">Dark</option>
                                </select>
                            </label>
                        </div>
                    </details>

                    <!-- Presets Panel -->
                    <details class="card" open>
                        <summary class="px-4 py-3 cursor-pointer text-sm font-medium text-gray-900 dark:text-white select-none hover:bg-gray-50 dark:hover:bg-gray-800 rounded-t-xl">
                            Preset Molecules
                        </summary>
                        <div class="px-4 pb-4 space-y-3 border-t border-gray-100 dark:border-gray-800 pt-4">
                            {Object.entries(playgroundPresets).map(([category, mols]) => (
                                <div>
                                    <div class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-1.5">{category}</div>
                                    <div class="flex flex-wrap gap-1.5">
                                        {mols.map(mol => (
                                            <button
                                                class="preset-btn text-xs px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-accent hover:text-accent transition-colors"
                                                data-smiles={mol.smiles}
                                            >
                                                {mol.name}
                                            </button>
                                        ))}
                                    </div>
                                </div>
                            ))}
                        </div>
                    </details>
                </div>
            </div>
        </div>

        <!-- Batch export panel -->
        <div id="panel-batch" class="hidden">
            <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-6">
                <!-- Main area -->
                <div class="space-y-4">
                    <!-- SMILES textarea input -->
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <label for="batch-input" class="text-sm font-medium text-gray-700 dark:text-gray-300">SMILES (one per line)</label>
                            <div class="flex items-center gap-2">
                                <span id="batch-count" class="text-xs text-gray-500 dark:text-gray-400">0 molecules</span>
                                <input type="file" id="batch-file-input" accept=".csv,.smi,.txt,.tsv" class="hidden">
                                <button id="batch-import-btn" class="text-xs px-2 py-0.5 rounded border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400 hover:border-accent hover:text-accent transition-colors">Import File</button>
                            </div>
                        </div>
                        <textarea
                            id="batch-input"
                            rows="6"
                            placeholder="c1ccccc1&#10;CC(=O)Oc1ccccc1C(=O)O&#10;Cn1c(=O)c2c(ncn2C)n(c1=O)C"
                            class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white font-mono text-sm focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent transition-all resize-y"
                            spellcheck="false"
                        ></textarea>
                    </div>

                    <!-- Batch error display -->
                    <div id="batch-error" class="text-sm text-red-500 dark:text-red-400 hidden"></div>

                    <!-- Action buttons -->
                    <div class="flex flex-wrap gap-3">
                        <button id="batch-render-btn" class="btn-primary">Render All</button>
                        <button id="batch-export-png" class="btn-secondary">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                            </svg>
                            Export PNG
                        </button>
                        <button id="batch-export-svg" class="btn-secondary">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                            </svg>
                            Export SVG
                        </button>
                    </div>

                    <!-- Pagination bar -->
                    <div id="batch-pagination" class="flex items-center justify-center gap-3 hidden">
                        <button id="batch-page-prev" class="btn-secondary text-xs px-3 py-1" disabled>&laquo; Prev</button>
                        <span id="batch-page-info" class="text-sm text-gray-600 dark:text-gray-400">Page 1 of 1</span>
                        <button id="batch-page-next" class="btn-secondary text-xs px-3 py-1" disabled>Next &raquo;</button>
                    </div>

                    <!-- Selection action bar -->
                    <div id="batch-selection-bar" class="flex items-center gap-3 px-4 py-2 rounded-lg bg-accent/10 border border-accent/20 hidden">
                        <span id="batch-selection-count" class="text-sm font-medium text-accent">0 selected</span>
                        <button id="batch-select-all" class="text-xs px-2 py-0.5 rounded border border-accent/30 text-accent hover:bg-accent/10 transition-colors">Select All</button>
                        <button id="batch-deselect-all" class="text-xs px-2 py-0.5 rounded border border-accent/30 text-accent hover:bg-accent/10 transition-colors">Deselect All</button>
                        <button id="batch-delete-selected" class="text-xs px-2 py-0.5 rounded border border-red-300 dark:border-red-700 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">Delete Selected</button>
                    </div>

                    <!-- Grid preview area -->
                    <div class="card p-4 sm:p-6">
                        <div id="batch-grid" class="grid gap-2" style="grid-template-columns: repeat(3, 1fr);">
                            <div class="flex items-center justify-center text-sm text-gray-400 dark:text-gray-500 col-span-full py-16">
                                Enter SMILES above and click "Render All"
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sidebar -->
                <div class="space-y-4">
                    <!-- Grid Layout Panel -->
                    <details class="card" open>
                        <summary class="px-4 py-3 cursor-pointer text-sm font-medium text-gray-900 dark:text-white select-none hover:bg-gray-50 dark:hover:bg-gray-800 rounded-t-xl">
                            Grid Layout
                        </summary>
                        <div class="px-4 pb-4 space-y-4 border-t border-gray-100 dark:border-gray-800 pt-4">
                            <!-- Grid presets -->
                            <div>
                                <div class="text-xs text-gray-600 dark:text-gray-400 mb-2">Presets</div>
                                <div class="flex flex-wrap gap-1.5">
                                    <button class="batch-grid-preset text-xs px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-accent hover:text-accent transition-colors" data-cols="2" data-rows="2">2x2</button>
                                    <button class="batch-grid-preset text-xs px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-accent hover:text-accent transition-colors" data-cols="3" data-rows="3">3x3</button>
                                    <button class="batch-grid-preset text-xs px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-accent hover:text-accent transition-colors" data-cols="3" data-rows="4">3x4</button>
                                    <button class="batch-grid-preset text-xs px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-accent hover:text-accent transition-colors" data-cols="4" data-rows="4">4x4</button>
                                    <button class="batch-grid-preset text-xs px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-accent hover:text-accent transition-colors" data-cols="5" data-rows="5">5x5</button>
                                </div>
                            </div>
                            <div>
                                <label class="flex items-center justify-between text-xs text-gray-600 dark:text-gray-400 mb-1">
                                    <span>Columns</span>
                                    <span id="batch-opt-cols-val" class="font-mono">3</span>
                                </label>
                                <input id="batch-opt-cols" type="range" min="1" max="8" value="3" step="1" class="w-full accent-accent">
                            </div>
                            <div>
                                <label class="flex items-center justify-between text-xs text-gray-600 dark:text-gray-400 mb-1">
                                    <span>Rows</span>
                                    <span id="batch-opt-rows-val" class="font-mono">3</span>
                                </label>
                                <input id="batch-opt-rows" type="range" min="1" max="10" value="3" step="1" class="w-full accent-accent">
                            </div>
                            <div>
                                <label class="flex items-center justify-between text-xs text-gray-600 dark:text-gray-400 mb-1">
                                    <span>Cell size (px)</span>
                                    <span id="batch-opt-cellSize-val" class="font-mono">250</span>
                                </label>
                                <input id="batch-opt-cellSize" type="range" min="100" max="500" value="250" step="10" class="w-full accent-accent">
                            </div>
                            <hr class="border-gray-100 dark:border-gray-800" />
                            <label class="flex items-center justify-between text-xs">
                                <span class="text-gray-600 dark:text-gray-400">Show labels</span>
                                <input id="batch-opt-showLabels" type="checkbox" checked class="accent-accent w-4 h-4">
                            </label>
                            <label class="flex items-center justify-between text-xs">
                                <span class="text-gray-600 dark:text-gray-400">Show formula</span>
                                <input id="batch-opt-showFormula" type="checkbox" class="accent-accent w-4 h-4">
                            </label>
                            <label class="flex items-center justify-between text-xs">
                                <span class="text-gray-600 dark:text-gray-400">Show mol. weight</span>
                                <input id="batch-opt-showMW" type="checkbox" class="accent-accent w-4 h-4">
                            </label>
                            <label class="flex items-center justify-between text-xs">
                                <span class="text-gray-600 dark:text-gray-400">Theme</span>
                                <select id="batch-opt-theme" class="text-xs bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded px-2 py-1">
                                    <option value="light">Light</option>
                                    <option value="dark">Dark</option>
                                </select>
                            </label>
                        </div>
                    </details>

                    <!-- Publication Export Panel -->
                    <details class="card">
                        <summary class="px-4 py-3 cursor-pointer text-sm font-medium text-gray-900 dark:text-white select-none hover:bg-gray-50 dark:hover:bg-gray-800 rounded-t-xl">
                            Publication Export
                        </summary>
                        <div class="px-4 pb-4 space-y-4 border-t border-gray-100 dark:border-gray-800 pt-4">
                            <div>
                                <div class="text-xs text-gray-600 dark:text-gray-400 mb-2">Export scale</div>
                                <div class="flex flex-wrap gap-1.5">
                                    <button class="batch-scale-preset text-xs px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-accent hover:text-accent transition-colors" data-scale="1">1x (72 DPI)</button>
                                    <button class="batch-scale-preset text-xs px-2.5 py-1 rounded-full border border-accent text-accent ring-2 ring-accent/30" data-scale="2">2x (144 DPI)</button>
                                    <button class="batch-scale-preset text-xs px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-accent hover:text-accent transition-colors" data-scale="3">3x (216 DPI)</button>
                                    <button class="batch-scale-preset text-xs px-2.5 py-1 rounded-full border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-accent hover:text-accent transition-colors" data-scale="4">4x (288 DPI)</button>
                                </div>
                            </div>
                            <hr class="border-gray-100 dark:border-gray-800" />
                            <label class="flex items-center justify-between text-xs">
                                <span class="text-gray-600 dark:text-gray-400">Transparent background</span>
                                <input id="batch-opt-transparentBg" type="checkbox" class="accent-accent w-4 h-4">
                            </label>
                            <label class="flex items-center justify-between text-xs">
                                <span class="text-gray-600 dark:text-gray-400">Force white background</span>
                                <input id="batch-opt-whiteBg" type="checkbox" class="accent-accent w-4 h-4">
                            </label>
                            <hr class="border-gray-100 dark:border-gray-800" />
                            <div>
                                <label class="text-xs text-gray-600 dark:text-gray-400 mb-1 block">Grid title</label>
                                <input id="batch-opt-title" type="text" placeholder="e.g. Figure 1 — Drug candidates" class="w-full text-xs px-2 py-1.5 rounded border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-900 dark:text-white focus:outline-none focus:ring-1 focus:ring-accent/50">
                            </div>
                        </div>
                    </details>

                    <!-- Drawing Options Panel -->
                    <details class="card" open>
                        <summary class="px-4 py-3 cursor-pointer text-sm font-medium text-gray-900 dark:text-white select-none hover:bg-gray-50 dark:hover:bg-gray-800 rounded-t-xl">
                            Drawing Options
                        </summary>
                        <div class="px-4 pb-4 space-y-4 border-t border-gray-100 dark:border-gray-800 pt-4">
                            <div>
                                <label class="flex items-center justify-between text-xs text-gray-600 dark:text-gray-400 mb-1">
                                    <span>Bond length</span>
                                    <span id="batch-opt-bondLength-val" class="font-mono">15</span>
                                </label>
                                <input id="batch-opt-bondLength" type="range" min="5" max="30" value="15" step="1" class="w-full accent-accent">
                            </div>
                            <div>
                                <label class="flex items-center justify-between text-xs text-gray-600 dark:text-gray-400 mb-1">
                                    <span>Bond thickness</span>
                                    <span id="batch-opt-bondThickness-val" class="font-mono">1</span>
                                </label>
                                <input id="batch-opt-bondThickness" type="range" min="0.5" max="5" value="1" step="0.5" class="w-full accent-accent">
                            </div>
                            <hr class="border-gray-100 dark:border-gray-800" />
                            <label class="flex items-center justify-between text-xs">
                                <span class="text-gray-600 dark:text-gray-400">Compact drawing</span>
                                <input id="batch-opt-compactDrawing" type="checkbox" class="accent-accent w-4 h-4">
                            </label>
                        </div>
                    </details>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script is:inline>
(function() {
    document.addEventListener('DOMContentLoaded', function() {
        var input = document.getElementById('pg-input');
        var svg = document.getElementById('pg-svg');
        var errorEl = document.getElementById('pg-error');
        var drawBtn = document.getElementById('pg-draw-btn');

        // Option elements
        var sliders = ['bondLength', 'bondThickness', 'bondSpacing', 'fontSizeLarge', 'width', 'height'];
        var checkboxes = ['terminalCarbons', 'explicitHydrogens', 'compactDrawing', 'debug'];

        function getOptions() {
            var opts = {};
            sliders.forEach(function(name) {
                var el = document.getElementById('opt-' + name);
                if (el) opts[name] = parseFloat(el.value);
            });
            checkboxes.forEach(function(name) {
                var el = document.getElementById('opt-' + name);
                if (el) opts[name] = el.checked;
            });
            return opts;
        }

        function getTheme() {
            var el = document.getElementById('opt-theme');
            return el ? el.value : 'light';
        }

        function draw() {
            var smiles = input.value.trim();
            if (!smiles) {
                svg.innerHTML = '';
                errorEl.classList.add('hidden');
                return;
            }

            var opts = getOptions();
            try {
                var drawer = new SmilesDrawer.SvgDrawer(opts);
                SmilesDrawer.parse(smiles, function(tree) {
                    svg.innerHTML = '';
                    drawer.draw(tree, svg, getTheme());
                    errorEl.classList.add('hidden');
                }, function(err) {
                    errorEl.textContent = 'Invalid SMILES: ' + err;
                    errorEl.classList.remove('hidden');
                });
            }
            catch (e) {
                errorEl.textContent = 'Error: ' + e.message;
                errorEl.classList.remove('hidden');
            }

            // Update URL
            var url = new URL(window.location);
            url.searchParams.set('smiles', smiles);
            window.history.replaceState({}, '', url);
        }

        // Debounced draw on input
        var debounceTimer;
        input.addEventListener('input', function() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(draw, 200);
        });

        input.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') draw();
        });

        drawBtn.addEventListener('click', draw);

        // Update slider value displays and redraw on change
        sliders.forEach(function(name) {
            var el = document.getElementById('opt-' + name);
            var valEl = document.getElementById('opt-' + name + '-val');
            if (el && valEl) {
                el.addEventListener('input', function() {
                    valEl.textContent = el.value;
                    draw();
                });
            }
        });

        checkboxes.forEach(function(name) {
            var el = document.getElementById('opt-' + name);
            if (el) el.addEventListener('change', draw);
        });

        var themeSelect = document.getElementById('opt-theme');
        if (themeSelect) {
            // Sync drawing theme selector to page dark mode
            themeSelect.value = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
            themeSelect.addEventListener('change', draw);
        }

        // Re-render when page dark mode toggles
        new MutationObserver(function(mutations) {
            mutations.forEach(function(m) {
                if (m.attributeName === 'class') {
                    var ts = document.getElementById('opt-theme');
                    if (ts) ts.value = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
                    draw();
                }
            });
        }).observe(document.documentElement, {attributes: true, attributeFilter: ['class']});

        // Preset buttons
        document.querySelectorAll('.preset-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                input.value = this.getAttribute('data-smiles');
                draw();
            });
        });

        // Download SVG
        document.getElementById('pg-download-svg').addEventListener('click', function() {
            var svgData = new XMLSerializer().serializeToString(svg);
            var blob = new Blob([svgData], {type: 'image/svg+xml'});
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url;
            a.download = 'molecule.svg';
            a.click();
            URL.revokeObjectURL(url);
        });

        // Download PNG
        document.getElementById('pg-download-png').addEventListener('click', function() {
            var svgData = new XMLSerializer().serializeToString(svg);
            var img = new Image();
            img.onload = function() {
                var canvas = document.createElement('canvas');
                var scale = 2;
                canvas.width = img.width * scale;
                canvas.height = img.height * scale;
                var ctx = canvas.getContext('2d');
                ctx.scale(scale, scale);
                ctx.drawImage(img, 0, 0);
                canvas.toBlob(function(blob) {
                    var url = URL.createObjectURL(blob);
                    var a = document.createElement('a');
                    a.href = url;
                    a.download = 'molecule.png';
                    a.click();
                    URL.revokeObjectURL(url);
                });
            };
            img.src = 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(svgData)));
        });

        // Copy SVG
        document.getElementById('pg-copy-svg').addEventListener('click', function() {
            var svgData = new XMLSerializer().serializeToString(svg);
            navigator.clipboard.writeText(svgData).then(function() {
                showToast('SVG copied to clipboard');
            });
        });

        // Copy SMILES
        document.getElementById('pg-copy-smiles').addEventListener('click', function() {
            navigator.clipboard.writeText(input.value).then(function() {
                showToast('SMILES copied to clipboard');
            });
        });

        // Share link
        document.getElementById('pg-share').addEventListener('click', function() {
            var url = new URL(window.location);
            url.searchParams.set('smiles', input.value);
            navigator.clipboard.writeText(url.toString()).then(function() {
                showToast('Link copied to clipboard');
            });
        });

        // Toast notification
        function showToast(message) {
            var existing = document.getElementById('toast');
            if (existing) existing.remove();
            var toast = document.createElement('div');
            toast.id = 'toast';
            toast.className = 'fixed bottom-4 right-4 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 text-sm px-4 py-2 rounded-lg shadow-lg z-50 transition-opacity duration-300';
            toast.textContent = message;
            document.body.appendChild(toast);
            setTimeout(function() {
                toast.style.opacity = '0';
                setTimeout(function() { toast.remove(); }, 300);
            }, 2000);
        }

        // Read SMILES from URL on load
        var params = new URLSearchParams(window.location.search);
        if (params.has('smiles')) {
            input.value = params.get('smiles');
        }

        draw();
    });
})();
</script>


<script is:inline>
(function() {
    document.addEventListener('DOMContentLoaded', function() {
        // ─── Tab switching ────────────────────────────────────────────
        var tabSingle = document.getElementById('tab-single');
        var tabBatch = document.getElementById('tab-batch');
        var panelSingle = document.getElementById('panel-single');
        var panelBatch = document.getElementById('panel-batch');

        function switchTab(tab) {
            if (tab === 'single') {
                panelSingle.classList.remove('hidden');
                panelBatch.classList.add('hidden');
                tabSingle.classList.add('border-accent', 'text-accent');
                tabSingle.classList.remove('border-transparent', 'text-gray-500', 'dark:text-gray-400');
                tabBatch.classList.remove('border-accent', 'text-accent');
                tabBatch.classList.add('border-transparent', 'text-gray-500', 'dark:text-gray-400');
            } else {
                panelSingle.classList.add('hidden');
                panelBatch.classList.remove('hidden');
                tabBatch.classList.add('border-accent', 'text-accent');
                tabBatch.classList.remove('border-transparent', 'text-gray-500', 'dark:text-gray-400');
                tabSingle.classList.remove('border-accent', 'text-accent');
                tabSingle.classList.add('border-transparent', 'text-gray-500', 'dark:text-gray-400');
                var bt = document.getElementById('batch-opt-theme');
                if (bt) bt.value = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
            }
        }

        tabSingle.addEventListener('click', function() { switchTab('single'); });
        tabBatch.addEventListener('click', function() { switchTab('batch'); });

        // ─── Batch DOM refs ───────────────────────────────────────────
        var batchInput = document.getElementById('batch-input');
        var batchCount = document.getElementById('batch-count');
        var batchGrid = document.getElementById('batch-grid');
        var batchError = document.getElementById('batch-error');
        var renderBtn = document.getElementById('batch-render-btn');
        var exportPngBtn = document.getElementById('batch-export-png');
        var exportSvgBtn = document.getElementById('batch-export-svg');
        var fileInput = document.getElementById('batch-file-input');
        var importBtn = document.getElementById('batch-import-btn');

        // Grid option elements
        var colsSlider = document.getElementById('batch-opt-cols');
        var colsVal = document.getElementById('batch-opt-cols-val');
        var rowsSlider = document.getElementById('batch-opt-rows');
        var rowsVal = document.getElementById('batch-opt-rows-val');
        var cellSizeSlider = document.getElementById('batch-opt-cellSize');
        var cellSizeVal = document.getElementById('batch-opt-cellSize-val');
        var showLabelsCheck = document.getElementById('batch-opt-showLabels');
        var batchTheme = document.getElementById('batch-opt-theme');

        // Drawing options
        var batchSliders = ['bondLength', 'bondThickness'];
        var batchCheckboxes = ['compactDrawing'];

        // ─── Data model ───────────────────────────────────────────────
        var batchData = [];

        // ─── Helpers ──────────────────────────────────────────────────
        function getBatchDrawOptions() {
            var opts = {};
            batchSliders.forEach(function(name) {
                var el = document.getElementById('batch-opt-' + name);
                if (el) opts[name] = parseFloat(el.value);
            });
            batchCheckboxes.forEach(function(name) {
                var el = document.getElementById('batch-opt-' + name);
                if (el) opts[name] = el.checked;
            });
            return opts;
        }

        function getBatchTheme() {
            return batchTheme ? batchTheme.value : 'light';
        }

        // ─── Parse batch input ────────────────────────────────────────
        function parseBatchInput() {
            var text = batchInput.value;
            var lines = text.split('\n').map(function(l) { return l.trim(); }).filter(function(l) { return l.length > 0; });
            batchData = [];
            lines.forEach(function(line) {
                var name = '';
                var smiles = line;
                if (line.indexOf('\t') !== -1) {
                    var parts = line.split('\t');
                    if (parts.length >= 2) { name = parts[0].trim(); smiles = parts[1].trim(); }
                } else if (line.indexOf(',') !== -1) {
                    var idx = line.indexOf(',');
                    var left = line.substring(0, idx).trim();
                    var right = line.substring(idx + 1).trim();
                    if (left && right && !/[=\[\]()#]/.test(left) && /[A-Za-z]/.test(right)) {
                        name = left;
                        smiles = right;
                    }
                }
                batchData.push({ name: name, smiles: smiles, selected: false });
            });
            updateBatchCount();
        }

        function syncTextareaFromData() {
            var lines = batchData.map(function(item) {
                if (item.name) return item.name + '\t' + item.smiles;
                return item.smiles;
            });
            batchInput.value = lines.join('\n');
            updateBatchCount();
        }

        function updateBatchCount() {
            var count = batchData.length;
            batchCount.textContent = count + ' molecule' + (count !== 1 ? 's' : '');
        }

        // ─── Render batch ────────────────────────────────────────────
        function renderBatch() {
            if (batchData.length === 0) {
                batchError.classList.add('hidden');
                batchGrid.innerHTML = '<div class="flex items-center justify-center text-sm text-gray-400 dark:text-gray-500 col-span-full py-16">Enter SMILES above and click "Render All"</div>';
                return;
            }

            var cols = parseInt(colsSlider.value);
            var cellSize = parseInt(cellSizeSlider.value);
            var showLabels = showLabelsCheck.checked;
            var theme = getBatchTheme();
            var drawOpts = getBatchDrawOptions();
            drawOpts.width = cellSize;
            drawOpts.height = cellSize;

            batchGrid.style.gridTemplateColumns = 'repeat(' + cols + ', 1fr)';
            batchGrid.innerHTML = '';
            batchError.classList.add('hidden');

            var errors = [];

            batchData.forEach(function(item, i) {
                var cell = document.createElement('div');
                cell.className = 'flex flex-col items-center p-2 rounded-lg border-2 border-transparent';

                var svgEl = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
                svgEl.setAttribute('class', 'batch-cell-svg');
                svgEl.style.width = cellSize + 'px';
                svgEl.style.height = cellSize + 'px';
                cell.appendChild(svgEl);

                var labelText = item.name || item.smiles;
                if (showLabels) {
                    var label = document.createElement('div');
                    label.className = 'text-xs text-gray-500 dark:text-gray-400 mt-1 truncate text-center font-mono';
                    label.style.maxWidth = cellSize + 'px';
                    label.textContent = labelText;
                    cell.appendChild(label);
                }

                batchGrid.appendChild(cell);

                try {
                    var drawer = new SmilesDrawer.SvgDrawer(drawOpts);
                    SmilesDrawer.parse(item.smiles, function(tree) {
                        drawer.draw(tree, svgEl, theme);
                    }, function(err) {
                        errors.push('Line ' + (i + 1) + ': ' + err);
                        svgEl.innerHTML = '<text x="50%" y="50%" text-anchor="middle" fill="red" font-size="12">Error</text>';
                    });
                } catch (e) {
                    errors.push('Line ' + (i + 1) + ': ' + e.message);
                    svgEl.innerHTML = '<text x="50%" y="50%" text-anchor="middle" fill="red" font-size="12">Error</text>';
                }
            });

            if (errors.length > 0) {
                batchError.textContent = errors.join('; ');
                batchError.classList.remove('hidden');
            }
        }

        // ─── Textarea input → parse + render ─────────────────────────
        batchInput.addEventListener('input', function() {
            parseBatchInput();
        });

        renderBtn.addEventListener('click', function() {
            parseBatchInput();
            renderBatch();
        });

        // ─── File import ─────────────────────────────────────────────
        importBtn.addEventListener('click', function() { fileInput.click(); });
        fileInput.addEventListener('change', function() {
            var file = fileInput.files[0];
            if (!file) return;
            var reader = new FileReader();
            reader.onload = function(e) {
                batchInput.value = e.target.result;
                parseBatchInput();
                renderBatch();
            };
            reader.readAsText(file);
            fileInput.value = '';
        });

        // ─── Wire up slider displays + auto-re-render ────────────────
        var batchRenderDebounce;
        function debouncedRender() {
            clearTimeout(batchRenderDebounce);
            batchRenderDebounce = setTimeout(function() {
                if (batchData.length > 0) renderBatch();
            }, 150);
        }

        colsSlider.addEventListener('input', function() { colsVal.textContent = colsSlider.value; debouncedRender(); });
        rowsSlider.addEventListener('input', function() { rowsVal.textContent = rowsSlider.value; debouncedRender(); });
        cellSizeSlider.addEventListener('input', function() { cellSizeVal.textContent = cellSizeSlider.value; debouncedRender(); });

        batchSliders.forEach(function(name) {
            var el = document.getElementById('batch-opt-' + name);
            var valEl = document.getElementById('batch-opt-' + name + '-val');
            if (el && valEl) {
                el.addEventListener('input', function() { valEl.textContent = el.value; debouncedRender(); });
            }
        });

        [showLabelsCheck].forEach(function(el) {
            if (el) el.addEventListener('change', function() { if (batchData.length > 0) renderBatch(); });
        });
        batchCheckboxes.forEach(function(name) {
            var el = document.getElementById('batch-opt-' + name);
            if (el) el.addEventListener('change', function() { if (batchData.length > 0) renderBatch(); });
        });

        // Grid presets
        document.querySelectorAll('.batch-grid-preset').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var c = parseInt(this.getAttribute('data-cols'));
                var r = parseInt(this.getAttribute('data-rows'));
                colsSlider.value = c;
                colsVal.textContent = c;
                rowsSlider.value = r;
                rowsVal.textContent = r;
                if (batchData.length > 0) renderBatch();
            });
        });

        // ─── Export PNG ──────────────────────────────────────────────
        exportPngBtn.addEventListener('click', function() {
            if (batchData.length === 0) return;

            var cols = parseInt(colsSlider.value);
            var cellSize = parseInt(cellSizeSlider.value);
            var showLabels = showLabelsCheck.checked;
            var labelHeight = showLabels ? 20 : 0;
            var cellTotal = cellSize + labelHeight;
            var rows = Math.ceil(batchData.length / cols);
            var scale = 2;
            var theme = getBatchTheme();
            var isDark = theme === 'dark';

            var drawOpts = getBatchDrawOptions();
            drawOpts.width = cellSize;
            drawOpts.height = cellSize;

            var canvas = document.createElement('canvas');
            canvas.width = cols * cellSize * scale;
            canvas.height = rows * cellTotal * scale;
            var ctx = canvas.getContext('2d');
            ctx.scale(scale, scale);

            ctx.fillStyle = isDark ? '#1a1a2e' : '#ffffff';
            ctx.fillRect(0, 0, cols * cellSize, rows * cellTotal);

            var loaded = 0;
            var total = batchData.length;

            batchData.forEach(function(item, i) {
                var col = i % cols;
                var row = Math.floor(i / cols);

                var svgEl = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
                svgEl.style.width = cellSize + 'px';
                svgEl.style.height = cellSize + 'px';
                document.body.appendChild(svgEl);
                try {
                    var drawer = new SmilesDrawer.SvgDrawer(drawOpts);
                    SmilesDrawer.parse(item.smiles, function(tree) { drawer.draw(tree, svgEl, theme); }, function() {});
                } catch (e) { /* skip */ }
                var svgData = new XMLSerializer().serializeToString(svgEl);
                document.body.removeChild(svgEl);

                var img = new Image();
                img.onload = function() {
                    ctx.drawImage(img, col * cellSize, row * cellTotal, cellSize, cellSize);
                    if (showLabels) {
                        ctx.fillStyle = isDark ? '#9ca3af' : '#6b7280';
                        ctx.font = '11px monospace';
                        ctx.textAlign = 'center';
                        var lt = item.name || item.smiles;
                        if (lt.length > 30) lt = lt.substring(0, 27) + '...';
                        ctx.fillText(lt, col * cellSize + cellSize / 2, row * cellTotal + cellSize + 14);
                    }
                    loaded++;
                    if (loaded === total) {
                        canvas.toBlob(function(blob) {
                            var url = URL.createObjectURL(blob);
                            var a = document.createElement('a');
                            a.href = url; a.download = 'molecules-grid.png'; a.click();
                            URL.revokeObjectURL(url);
                        });
                    }
                };
                img.onerror = function() { loaded++; if (loaded === total) { canvas.toBlob(function(blob) { var url = URL.createObjectURL(blob); var a = document.createElement('a'); a.href = url; a.download = 'molecules-grid.png'; a.click(); URL.revokeObjectURL(url); }); } };
                img.src = 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(svgData)));
            });
        });

        // ─── Export SVG ──────────────────────────────────────────────
        exportSvgBtn.addEventListener('click', function() {
            if (batchData.length === 0) return;

            var cols = parseInt(colsSlider.value);
            var cellSize = parseInt(cellSizeSlider.value);
            var showLabels = showLabelsCheck.checked;
            var labelHeight = showLabels ? 20 : 0;
            var cellTotal = cellSize + labelHeight;
            var rows = Math.ceil(batchData.length / cols);
            var totalWidth = cols * cellSize;
            var totalHeight = rows * cellTotal;
            var theme = getBatchTheme();
            var isDark = theme === 'dark';

            var drawOpts = getBatchDrawOptions();
            drawOpts.width = cellSize;
            drawOpts.height = cellSize;

            var parts = [];
            parts.push('<svg xmlns="http://www.w3.org/2000/svg" width="' + totalWidth + '" height="' + totalHeight + '">');
            parts.push('<rect width="' + totalWidth + '" height="' + totalHeight + '" fill="' + (isDark ? '#1a1a2e' : '#ffffff') + '"/>');

            batchData.forEach(function(item, i) {
                var col = i % cols;
                var row = Math.floor(i / cols);
                var x = col * cellSize;
                var y = row * cellTotal;

                var svgEl = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
                svgEl.style.width = cellSize + 'px';
                svgEl.style.height = cellSize + 'px';
                document.body.appendChild(svgEl);
                try {
                    var drawer = new SmilesDrawer.SvgDrawer(drawOpts);
                    SmilesDrawer.parse(item.smiles, function(tree) { drawer.draw(tree, svgEl, theme); }, function() {});
                } catch (e) { /* skip */ }
                var viewBox = svgEl.getAttribute('viewBox') || '0 0 ' + cellSize + ' ' + cellSize;
                var innerHTML = svgEl.innerHTML;
                document.body.removeChild(svgEl);

                parts.push('<g transform="translate(' + x + ',' + y + ')">');
                parts.push('<svg width="' + cellSize + '" height="' + cellSize + '" viewBox="' + viewBox + '">');
                parts.push(innerHTML);
                parts.push('</svg>');

                if (showLabels) {
                    var lt = item.name || item.smiles;
                    if (lt.length > 30) lt = lt.substring(0, 27) + '...';
                    var esc = function(t) { return t.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); };
                    parts.push('<text x="' + (cellSize / 2) + '" y="' + (cellSize + 14) + '" text-anchor="middle" font-family="monospace" font-size="11" fill="' + (isDark ? '#9ca3af' : '#6b7280') + '">' + esc(lt) + '</text>');
                }

                parts.push('</g>');
            });

            parts.push('</svg>');

            var blob = new Blob([parts.join('')], { type: 'image/svg+xml' });
            var url = URL.createObjectURL(blob);
            var a = document.createElement('a');
            a.href = url; a.download = 'molecules-grid.svg'; a.click();
            URL.revokeObjectURL(url);
        });

        // ─── Dark mode sync ──────────────────────────────────────────
        new MutationObserver(function(mutations) {
            mutations.forEach(function(m) {
                if (m.attributeName === 'class') {
                    var bt = document.getElementById('batch-opt-theme');
                    if (bt) bt.value = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
                    if (!panelBatch.classList.contains('hidden') && batchData.length > 0) {
                        renderBatch();
                    }
                }
            });
        }).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

        if (batchTheme) {
            batchTheme.value = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
            batchTheme.addEventListener('change', function() {
                if (batchData.length > 0) renderBatch();
            });
        }
    });
})();
</script>
