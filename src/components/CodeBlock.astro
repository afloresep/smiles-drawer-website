---
interface Props {
    code: string;
    lang?: string;
    filename?: string;
}

const {code, lang = '', filename = ''} = Astro.props;
---
<div class="relative group rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700">
    {filename && (
        <div class="flex items-center justify-between px-4 py-2 bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 text-xs text-gray-500 dark:text-gray-400 font-mono">
            {filename}
        </div>
    )}
    <div class="relative">
        <pre class="overflow-x-auto p-4 text-sm leading-relaxed bg-gray-50 dark:bg-gray-900"><code class={lang ? `language-${lang}` : ''} set:html={code} /></pre>
        <button
            class="copy-btn absolute top-2 right-2 p-1.5 rounded-md bg-gray-200/80 dark:bg-gray-700/80 text-gray-600 dark:text-gray-300 opacity-0 group-hover:opacity-100 hover:bg-gray-300 dark:hover:bg-gray-600 transition-all text-xs"
            data-code={code}
        >
            Copy
        </button>
    </div>
</div>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.copy-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var code = this.getAttribute('data-code');
            navigator.clipboard.writeText(code).then(function() {
                btn.textContent = 'Copied!';
                setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
            });
        });
    });
});
</script>
