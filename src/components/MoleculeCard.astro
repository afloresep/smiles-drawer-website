---
interface Props {
    name: string;
    smiles: string;
    showPlaygroundLink?: boolean;
    showDownload?: boolean;
    clickable?: boolean;
    wide?: boolean;
    weights?: string;
    highlights?: Array<[number, string]>;
    reactionWeights?: {reactants?: number[][]; reagents?: number[][]; products?: number[][]};
    render?: Record<string, any>;
}

const {name, smiles, showPlaygroundLink = false, showDownload = false, clickable = false, wide = false, weights, highlights, reactionWeights, render} = Astro.props;
const cardId = `mol-${name.replace(/\s+/g, '-').toLowerCase()}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<div
    class:list={[
        'group border border-ink rounded-md bg-white overflow-hidden flex flex-col transition-colors',
        clickable && 'cursor-pointer hover:bg-mint-tint',
        wide && 'sm:col-span-2'
    ]}
    data-smiles={smiles}
    data-molecule-card={clickable ? 'true' : undefined}>
    <div
        class:list={[
            'grid-paper flex items-center justify-center p-4',
            wide ? 'aspect-[2/1]' : 'aspect-square'
        ]}
        data-theme-surface="true">
        <svg
            id={cardId}
            data-smiles={smiles}
            class:list={['molecule-svg w-full h-full', (weights || reactionWeights) && 'weight-svg']}
            data-smiles-weights={weights || undefined}
            data-smiles-options={weights ? '{"opacity":0.7}' : undefined}
            data-smiles-highlights={highlights ? JSON.stringify(highlights) : undefined}
            data-smiles-reaction-weights={reactionWeights ? JSON.stringify(reactionWeights) : undefined}
            data-render-config={render ? JSON.stringify(render) : undefined}
        ></svg>
    </div>
    <div class="px-4 py-3 border-t border-rule">
        <div class="text-[12px] font-semibold text-ink truncate">{name}</div>
        <div class="font-mono text-[10px] text-ink-hint truncate mt-0.5" title={smiles}>{smiles}</div>
    </div>
    {(showPlaygroundLink || showDownload) && (
        <div class="flex border-t border-rule">
            {showPlaygroundLink && (
                <a
                    href={`${base}/playground?smiles=${encodeURIComponent(smiles)}`}
                    class="flex-1 py-2.5 text-center text-[10px] font-bold uppercase tracking-[0.06em] text-ink hover:bg-paper border-r border-rule last:border-r-0">
                    Open in Playground
                </a>
            )}
            {showDownload && (
                <button
                    type="button"
                    class="download-svg-btn flex-1 py-2.5 text-[10px] font-bold uppercase tracking-[0.06em] text-ink hover:bg-paper"
                    data-target={cardId}>
                    Download SVG
                </button>
            )}
        </div>
    )}
</div>
